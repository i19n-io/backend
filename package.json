{
  "name": "@i19n/backend",
  "version": "0.0.0",
  "homepage": "https://github.com/i19n-io/backend",
  "repository": "i19n-io/backend",
  "author": "Vova Revenko <vova@revenko.org>",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "dev:debug": "nest start --watch --debug",
    "cli": "ts-node -r tsconfig-paths/register src/cli",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "check": "run-p --continue-on-error check:*",
    "check:code": "eslint . --ext .ts --max-warnings 0",
    "check:format": "prettier . --check",
    "check:spelling": "cspell lint",
    "check:spelling-unused": "cspell-check-unused-words",
    "check:types": "tsc --noEmit",
    "fix": "run-s fix:*",
    "fix:code": "npm run check:code -- --fix",
    "fix:format": "npm run check:format -- --write",
    "fix:spelling-unused": "npm run check:spelling-unused -- --fix",
    "test": "vitest",
    "test:ui": "vitest --ui --coverage",
    "test:e2e": "vitest run --project e2e",
    "test:e2e:ui": "vitest --project e2e --ui",
    "test:unit": "vitest --project unit",
    "test:unit:ui": "vitest --project unit --ui --coverage",
    "test:unit:coverage": "vitest --project unit --coverage"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.12",
    "@nestjs/graphql": "^13.2.3",
    "@nestjs/mercurius": "^13.2.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.12",
    "@nestjs/swagger": "^11.2.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "drizzle-orm": "^0.44.6",
    "graphql": "^16.11.0",
    "graphql-scalars": "^1.25.0",
    "joi": "^17.13.3",
    "mercurius": "^16.5.0",
    "nest-commander": "^3.20.1",
    "passport": "^0.7.0",
    "passport-github": "^1.1.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.12",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.13.5",
    "@testcontainers/postgresql": "^11.7.1",
    "@types/node": "^24.8.1",
    "@types/passport-github": "^1.1.13",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "^1.3.23",
    "@vitest/ui": "^3.2.4",
    "cspell": "^9.2.1",
    "cspell-check-unused-words": "^1.5.4",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-consistent-default-export-name": "^0.0.15",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-node-import": "^1.0.5",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^60.0.0",
    "globals": "^16.4.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24"
    },
    "packageManager": {
      "name": "npm",
      "version": "^11"
    }
  }
}
