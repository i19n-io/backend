{
  "name": "@i19n/backend",
  "version": "0.0.0",
  "homepage": "https://github.com/i19n-io/backend",
  "repository": "i19n-io/backend",
  "author": "Vova Revenko <vova@revenko.org>",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "dev:debug": "nest start --watch --debug",
    "cli": "ts-node -r tsconfig-paths/register src/cli",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "check": "run-p --continue-on-error check:*",
    "check:code": "eslint . --ext .mjs,.ts --max-warnings 0",
    "check:format": "prettier . --check",
    "check:spelling": "cspell lint",
    "check:spelling:unused": "cspell-check-unused-words",
    "check:types": "tsc --noEmit",
    "fix": "run-s fix:*",
    "fix:code": "npm run check:code -- --fix",
    "fix:format": "npm run check:format -- --write",
    "fix:spelling:unused": "npm run check:spelling:unused -- --fix",
    "test": "run-s --continue-on-error test:{unit:cov,e2e}",
    "test:e2e": "jest --config tests/jest.config.ts",
    "test:unit": "jest --no-cache",
    "test:unit:cov": "jest --coverage"
  },
  "dependencies": {
    "@fastify/static": "^8.2.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.1.0",
    "@nestjs/mercurius": "^13.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "drizzle-orm": "^0.44.4",
    "graphql": "^16.11.0",
    "graphql-scalars": "^1.24.2",
    "joi": "^17.13.3",
    "mercurius": "^16.2.0",
    "nest-commander": "^3.18.0",
    "passport": "^0.7.0",
    "passport-github": "^1.1.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.1",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/passport-github": "^1.1.12",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.2",
    "cspell": "^9.2.0",
    "cspell-check-unused-words": "^1.5.3",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-consistent-default-export-name": "^0.0.15",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-node-import": "^1.0.5",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-unicorn": "^60.0.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jiti": "^2.5.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "node": "^22",
    "npm": "^10"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^22"
    },
    "packageManager": {
      "name": "npm",
      "version": "^10"
    }
  }
}
