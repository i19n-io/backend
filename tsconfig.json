{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "CommonJS",
    "target": "ESNext",

    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "incremental": true,
    "isolatedModules": true,
    "noFallthroughCasesInSwitch": true,
    "removeComments": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,

    "baseUrl": "./",
    "outDir": "./dist",

    "paths": {
      "~/e2e/*": ["./e2e/*"],
      "~/*": ["./src/*"]
    }
  }
}
